# ===== FreeFlow LLM providers — you only need at least ONE of these, but adding =====
# ===== more than one increases your pooled free rate limit (Groq -> Gemini -> GitHub) =====

# Groq (recommended, fastest, ~14,400 requests/day free) — https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

# Google Gemini (~1,500 requests/day free) — https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# GitHub Models (rate limited but free) — https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# ===== Backend settings =====
# Comma-separated list of origins allowed to call this backend, or * for any origin
ALLOWED_ORIGINS=*

# Max requests per client IP per minute (protects your pooled free-tier keys)
RATE_LIMIT_PER_MIN=20

# SQLite cache/database file — users, sessions, payment requests, and cached lessons
DB_PATH=enlight_cache.db

# Folder where uploaded proof-of-payment files are stored
UPLOAD_DIR=uploads

# How many days a login session stays valid before the student has to log in again
SESSION_DAYS_VALID=30

# Log level: INFO, WARNING, ERROR, DEBUG
LOG_LEVEL=INFO

# Port the server listens on (Railway sets this automatically)
PORT=8000

# ===== Creator account (free forever + admin access) =====
# Logging in with this email and ANY password ending in CREATOR_PASSWORD_SUFFIX always
# grants free, permanent, admin access (creates the account automatically on first use).
# Keep this email private once deployed — see the SECURITY NOTE at the top of app.py.
CREATOR_EMAIL=zwanelwazi04@gmail.com
CREATOR_PASSWORD_SUFFIX=4560Lwazi#Zwane

# ===== Password reset emails (optional) =====
# Without these, "Forgot Password" still works (no error shown to students), but no
# email actually goes out — you'll see a WARNING in the logs instead. To enable real
# emails using Gmail: turn on 2-Step Verification on enlightquants@gmail.com, then create
# an "App Password" at https://myaccount.google.com/apppasswords and use it below
# (NOT your normal Gmail password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=enlightquants@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
SMTP_FROM=ENLIGHT RSA <enlightquants@gmail.com>

# The public URL where enlight_rsa.html is hosted — used to build the password-reset
# link sent by email (e.g. https://enlightrsa.com). Leave blank while testing locally.
FRONTEND_URL=

# NOTE: No YouTube API key is needed. Video links are built for free, without any
# external API call — see /api/lesson-video in app.py.
